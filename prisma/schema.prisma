generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Game {
  id           String      @id @default(cuid())
  title        String
  description  String
  category     String      @default("HTML5") // HTML5, UNITY_WEBGL, FLASH
  genre        String      @default("")      // Action, Puzzle, Racing, Shooter, etc.
  thumbnailUrl String      @default("")
  videoUrl     String      @default("")
  gameUrl      String
  plays        Int         @default(0)
  rating       Float       @default(0)
  featured     Boolean     @default(false)
  tags         String      @default("")
  sourceId     String?
  source       GameSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  externalId   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([sourceId])
  @@index([genre])
}

model GameSource {
  id            String   @id @default(cuid())
  name          String
  type          String   // CRAZYGAMES, POKI, CUSTOM
  baseUrl       String
  isActive      Boolean  @default(true)
  gamesFetched  Int      @default(0)
  lastFetched   DateTime?
  searchQuery   String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  games         Game[]
}
